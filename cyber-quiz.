<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ethical Hacker & Cyber Security Challenge</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Courier New', Courier, monospace; background: #08080a; color: #00ff66; display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; }
        .container { background: #101014; padding: 30px 25px; border-radius: 12px; box-shadow: 0 0 25px rgba(0, 255, 102, 0.25); max-width: 500px; width: 100%; text-align: center; border: 1px solid #00ff66; }
        
        .profile-pic { width: 85px; height: 85px; border-radius: 50%; object-fit: cover; margin-bottom: 15px; border: 2px solid #00ff66; }
        h2 { font-size: 20px; margin-bottom: 5px; color: #00ff66; text-transform: uppercase; letter-spacing: 2px; }
        .system-status { font-size: 12px; color: #888; margin-bottom: 20px; text-transform: uppercase; }
        
        .progress-bar { width: 100%; background: #222; height: 6px; border-radius: 3px; margin-bottom: 25px; overflow: hidden; }
        .progress { width: 20%; background: #00ff66; height: 100%; transition: width 0.3s ease; }
        
        .question-box { text-align: left; margin-bottom: 20px; color: #ffffff; font-size: 15px; line-height: 1.5; min-height: 60px; }
        .options-box { display: flex; flex-direction: column; gap: 12px; }
        .option-btn { background: #14141c; color: #ffffff; border: 1px solid #333; padding: 14px; text-align: left; border-radius: 6px; cursor: pointer; font-size: 14px; font-family: 'Courier New', monospace; transition: all 0.2s ease; }
        .option-btn:hover { border-color: #00ff66; background: rgba(0, 255, 102, 0.08); padding-left: 18px; }
        
        .btn-whatsapp { background: #25D366; color: #fff; border: none; padding: 15px 20px; font-size: 16px; font-weight: bold; border-radius: 6px; cursor: pointer; width: 100%; transition: background 0.3s ease; display: inline-block; text-decoration: none; margin-top: 15px; font-family: Arial, sans-serif; box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3); }
        .btn-whatsapp:hover { background: #20ba59; }
        .hidden { display: none !important; }
        
        .loading { color: #ff3333; font-weight: bold; animation: blink 1s infinite; margin: 20px 0; letter-spacing: 1px; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    </style>
</head>
<body>
    <div class="container">
        <img src="Snapchat-1986047837.jpg" alt="System Terminal" class="profile-pic" onerror="this.style.display='none'">
        
        <h2>CYBER SHIELD SECURE-TEST</h2>
        <div class="system-status">Terminal: Active // Nodes: Checked</div>
        
        <div id="quiz-section">
            <div class="progress-bar"><div class="progress" id="quiz-progress"></div></div>
            <div class="question-box" id="question-text">Initializing security vectors...</div>
            <div class="options-box" id="options-container"></div>
        </div>

        <div id="loading-section" class="hidden">
            <p class="loading">[!] DECRYPTING SCORE MATRIX...</p>
            <p style="color: #aaa; font-size: 13px;">Compiling audit logs and grading security bypass risks.</p>
        </div>

        <div id="lock-screen" class="hidden">
            <p style="color: #ff3333; font-weight: bold; font-size: 18px; margin-bottom: 12px;">🔒 SECURITY ANALYSIS COMPLETED</p>
            <p style="margin-bottom: 20px; color: #b3b3c2; line-height: 1.6; font-size: 14px;">Your Hacker Penetration Rank and core vulnerability profile are locked. Join our official WhatsApp channel below to instantly unlock your score certificate and view correct answers!</p>
            <button class="btn-whatsapp" onclick="verifyAndUnlock()">Unlock My Security Rank 🔓</button>
        </div>
        
        <div id="result-box" class="hidden">
            <p style="color: #00ff66; font-weight: bold; font-size: 20px; margin-bottom: 10px;">👑 CERTIFIED RANK: ETHICAL DEFENDER</p>
            <p style="color: #fff; font-size: 14px; margin-bottom: 15px; line-height: 1.5; text-align: left;">Scan verified. Your systems are moderately safe, but hackers use advanced social engineering methods. Review the protocol keys below to fully harden your security parameters.</p>
            <div style="background: #14141c; padding: 12px; border-radius: 6px; text-align: left; font-size: 13px; color: #8a8a98; border: 1px solid #333;">
                <b style="color: #00ff66; display: block; margin-bottom: 5px;">🔥 CORE SECURITY CHEAT-SHEET:</b>
                • Never reuse passwords across multiple apps.<br>
                • Check browser URLs carefully before entering login data.<br>
                • Keep your operating system software up to date.
            </div>
        </div>
    </div>

    <script>
        // Paste your WhatsApp channel link here
        const WHATSAPP_LINK = "https://whatsapp.com/channel/0029Vb7hRMXISTkFZJkgWG1J";
        
        const quizData = [
            { q: "1. What is a 'Brute Force' attack used for by hackers?", a: ["Cracking passwords by trying thousands of combinations", "Crashing a physical computer motherboard", "Stealing fiber optic internet cables directly"], c: 0 },
            { q: "2. If a hacker installs software on your phone that secretly records everything you type (including passwords), what is it called?", a: ["Phishing wave", "Keylogger (Spyware)", "Ransomware bypass"], c: 1 },
            { q: "3. What is the safest way to browse public Wi-Fi networks (like at a cafe or airport)?", a: ["Turn off your phone's Bluetooth", "Use a secure VPN (Virtual Private Network)", "Clear your browser cookies before connecting"], c: 1 },
            { q: "4. A website link shows as 'http://secure-facebook.login-update.com'. Is it real?", a: ["Yes, it says secure right in the link text", "Yes, it goes to Facebook's server parameters", "No, it is a fake domain setup for phishing"], c: 2 },
            { q: "5. What does an 'Ethical Hacker' (White Hat) do?", a: ["Steals bank data to give money to charity groups", "Finds system security weaknesses legally to fix them", "Breaks company servers to destroy private databases"], c: 1 }
        ];

        let currentIdx = 0;

        function loadQuestion() {
            if (currentIdx >= quizData.length) {
                showLockScreen();
                return;
            }
            document.getElementById("quiz-progress").style.width = ((currentIdx + 1) / quizData.length * 100) + "%";
            const currentQ = quizData[currentIdx];
            document.getElementById("question-text").innerText = currentQ.q;
            
            const container = document.getElementById("options-container");
            container.innerHTML = "";
            currentQ.a.forEach((opt, idx) => {
                const btn = document.createElement("button");
                btn.className = "option-btn";
                btn.innerText = opt;
                btn.onclick = () => { currentIdx++; loadQuestion(); };
                container.appendChild(btn);
            });
        }

        function showLockScreen() {
            document.getElementById("quiz-section").classList.add("hidden");
            document.getElementById("loading-section").classList.remove("hidden");
            
            setTimeout(() => {
                document.getElementById("loading-section").classList.add("hidden");
                document.getElementById("lock-screen").classList.remove("hidden");
            }, 2500);
        }

        function verifyAndUnlock() {
            window.open(WHATSAPP_LINK, '_blank');
            document.getElementById('lock-screen').classList.add('hidden');
            document.getElementById('result-box').classList.remove('hidden');
        }

        // Run terminal script
        loadQuestion();
    </script>
</body>
</html>
